{
  "name": "@echo-blue/ngx-jsoneditor",
  "version": "20.0.1",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/echo-blue/ngx-jsoneditor"
  },
  "author": "https://www.linkedin.com/in/mariomol",
  "contributors": [
    "https://github.com/echo-blue"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "watch": "npm run build:lib -- --watch",
    "prep": "rm -f package-lock.json && rm -rf node_modules && npm i && npm run test && npm run build:full && npm start",
    "build": "ng build",
    "build:app": "npm run build:lib && ng build",
    "build:lib": "ng build --project @echo-blue/ngx-jsoneditor",
    "build:full": "npm run build:lib && npm run build:app",
    "publishnpm": "cp README.md projects/ngx-jsoneditor/README.md && npm run build:lib && cd dist/ngx-jsoneditor && npm publish --access=public",
    "unpublish": "npm deprecate -f '@echo-blue/ngx-jsoneditor@20.0.1' 'this package has been deprecated'",
    "test": "npm run test:unit",
    "test:dev": "vitest",
    "test:unit": "vitest run",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "ports": "lsof -i tcp:4201",
    "reinstall": "rm package-lock.json && rm -rf node_modules && npm i",
    "rebuildsass": "npm rebuild node-sass"
  },
  "dependencies": {
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "jsoneditor": "*",
    "rxjs": "*",
    "tslib": "^2.3.0",
    "webpack": "^5.88.2",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "^2.3.1",
    "@angular-devkit/schematics": "^20.3.20",
    "@angular-eslint/builder": "^20.7.0",
    "@angular-eslint/eslint-plugin": "^20.7.0",
    "@angular-eslint/eslint-plugin-template": "^20.7.0",
    "@angular-eslint/schematics": "^20.7.0",
    "@angular-eslint/template-parser": "^20.7.0",
    "@angular/build": "^20.3.20",
    "@angular/cli": "^20.3.20",
    "@angular/compiler-cli": "^20.3.18",
    "@angular/language-service": "^20.3.18",
    "@types/jsoneditor": "^9.9.3",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "@typescript-eslint/types": "^8.57.0",
    "@typescript-eslint/utils": "^8.57.0",
    "cpr": "^3.0.1",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-prefer-arrow": "latest",
    "jsdom": "^29.0.0",
    "ng-packagr": "^20.3.2",
    "typescript": "5.9.3",
    "vite": "^8.0.0",
    "vitest": "^3.1.1"
  }
}
