{
  "name": "@echo-blue/ng-jsoneditor",
  "version": "21.0.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/echo-blue/ng-jsoneditor"
  },
  "author": "https://www.linkedin.com/in/mariomol",
  "contributors": [
    "https://github.com/echo-blue"
  ],
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:app": "npm run build:lib && ng build",
    "build:lib": "ng build --project ng-jsoneditor",
    "watch": "npm run build:lib -- --watch",
    "build:full": "npm run build:lib && npm run build:app",
    "publishnpm": "cp README.md projects/ng-jsoneditor/README.md && npm run build:lib && cd dist/ng-jsoneditor && npm publish",
    "unpublish": "npm deprecate -f 'ng-jsoneditor@21.0.0' 'this package has been deprecated'",
    "test": "npm run test:dev && npm run e2e",
    "test:dev": "ng test --project ng-jsoneditor-demo",
    "test:unit": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "ports": "lsof -i tcp:4201",
    "reinstall": "rm package-lock.json && rm -rf node_modules && npm i",
    "rebuildsass": "npm rebuild node-sass"
  },
  "dependencies": {
    "@angular/common": "^21.2.4",
    "@angular/compiler": "^21.2.4",
    "@angular/core": "^21.2.4",
    "@angular/forms": "^21.2.4",
    "@angular/platform-browser": "^21.2.4",
    "@angular/platform-browser-dynamic": "^21.2.4",
    "@angular/router": "^21.2.4",
    "jsoneditor": "*",
    "ng-packagr": "^21.2.0",
    "rxjs": "*",
    "tslib": "^2.3.0",
    "webpack": "^5.88.2",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/schematics": "^21.2.2",
    "@angular-eslint/builder": "^21.3.0",
    "@angular-eslint/eslint-plugin": "^21.3.0",
    "@angular-eslint/eslint-plugin-template": "^21.3.0",
    "@angular-eslint/schematics": "^21.3.0",
    "@angular-eslint/template-parser": "^21.3.0",
    "@angular/build": "^21.2.2",
    "@angular/cli": "^21.2.2",
    "@angular/compiler-cli": "^21.2.4",
    "@angular/language-service": "^21.2.4",
    "@types/jasmine": "~6.0.0",
    "@types/jsoneditor": "^9.9.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cpr": "^3.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "latest",
    "eslint-plugin-jsdoc": "latest",
    "eslint-plugin-prefer-arrow": "latest",
    "jasmine-core": "~6.1.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "typescript": "5.9.3"
  }
}
